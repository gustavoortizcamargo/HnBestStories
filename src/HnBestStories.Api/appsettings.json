{
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com/v0/"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Cache": {
    "BestStoriesTopTtlMinutes": 5,
    "StaleCacheTtlMinutes": 60
  },
  "Resilience": {
    "TimeoutSeconds": 5,
    "RetryCount": 3,
    "CircuitBreakerHandledEventsAllowedBeforeBreaking": 5,
    "CircuitBreakerDurationSeconds": 30
  },
  "Worker": {
    "RefreshIntervalMinutes": 5
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
